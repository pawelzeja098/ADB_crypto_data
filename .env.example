# CoinGecko API
COINGECKO_API_KEY=your_api_key_here
# Use "demo" for free tier, "pro" for paid tier
COINGECKO_PLAN=demo

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crypto_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Ingestion settings
TRACKED_COINS=bitcoin,ethereum,binancecoin,solana,ripple,cardano,dogecoin,polkadot,avalanche-2,chainlink
INGEST_INTERVAL_SECONDS=60
